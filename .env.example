# Flask
FLASK_APP=run.py
FLASK_ENV=development
APP_NAME=Vitorando Music
SECRET_KEY=change-me
APP_BASE_URL=http://localhost:5000

# Database
# Local dev fallback:
DATABASE_URL=sqlite:///streaming_music.db
# Production example (Neon/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Multi-tenant
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=Workspace Padrao

# Billing / Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# Account security
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
PASSWORD_RESET_TOKEN_EXP_HOURS=1

# Mail / SMTP
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=no-reply@streamingmusic.local

# Rate limit and observability
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
SENTRY_DSN=
