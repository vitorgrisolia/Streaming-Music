# Configuracao do Flask
FLASK_APP=run.py
FLASK_ENV=production
APP_NAME=Victorando Music
SECRET_KEY=sua-chave-secreta-super-segura-aqui
APP_BASE_URL=https://streaming-music-victorando.onrender.com

# Configuracao do Banco de Dados
DATABASE_URL=postgresql://streaming_music_db_user:32faCrbH8Lg94E9QyHEWgdKd6P71968g@dpg-d7t1pdugvqtc73a68mlg-a/streaming_music_db
# Para PostgreSQL, use:
