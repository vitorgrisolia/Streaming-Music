# Multi-tenant
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=Workspace Padrao

# Stripe
STRIPE_SECRET_KEY=sk_test_substitua_aqui
STRIPE_PUBLISHABLE_KEY=pk_test_substitua_aqui
STRIPE_WEBHOOK_SECRET=whsec_substitua_aqui
STRIPE_PRICE_ID_FREE=price_substitua_free
STRIPE_PRICE_ID_PRO=price_substitua_pro
STRIPE_PRICE_ID_BUSINESS=price_substitua_business

# Seguranca de conta
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_EMAIL=true
PASSWORD_RESET_TOKEN_EXP_HOURS=1

# Envio de e-mail (SMTP)
